        {
          "name": "GET non-existent user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 404',()=>{",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Body is empty object',()=>{",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.deep.equal({});",
                  "});",
