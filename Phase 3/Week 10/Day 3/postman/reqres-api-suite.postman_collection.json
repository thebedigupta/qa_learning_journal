          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 400',()=>{",
                  "    pm.response.to.have.status(400);",
                  "})",
                  "",
                  "pm.test('Show date',()=>{",
                  "   const date = pm.response.headers.get(\"Date\");",
                  "   console.log(date);",
                  "})",
                  "",
                  "pm.test('Error message is correct',()=>{",
                  "    pm.expect(pm.response.json().error).to.eql('Missing email or username');",
                  "})",
                  "",
                  "pm.test('Return error property in response',()=>{",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error')",
                  "})"
                ],
